# Upstash Redis credentials (required for rate limiting)
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token

# API Keys configuration (JSON object)
API_KEYS={"ek_your_api_key_here":{"tier":"starter","name":"Development Key"}}

# Demo API key for Pattern B demo authentication (not committed to repo)
DEMO_API_KEY=ek_demo_key_here